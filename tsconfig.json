{
  "compileOnSave": false,
  "include": ["src/**/*"],
  "compilerOptions": {
    "rootDir": "src",
    "target": "ES2022",
    "module": "ES2022",
    "declaration": true,
    "declarationMap": false,
    "sourceMap": true,
    "inlineSources": true,
    "strict": true,
    "moduleResolution": "bundler",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "lib": ["ES2022", "DOM"],
    "skipLibCheck": true
  },
  "angularCompilerOptions": {
    "compilationMode": "partial"
  }
}